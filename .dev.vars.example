# The Worker talks to the external extractor bridge.
EXTRACTOR_URL=http://127.0.0.1:9010/
DOWNLOAD_TOKEN_SECRET=replace-with-a-long-random-string

# Optional: use one of these if your extractor is protected.
# EXTRACTOR_API_KEY=
# EXTRACTOR_BEARER_TOKEN=

# Tiny-VPS-friendly defaults: extract one URL at a time and allow yt-dlp enough time.
# EXTRACTOR_TIMEOUT_MS=90000
# MAX_BATCH_SIZE=25
# MAX_UPSTREAM_CONCURRENCY=1
