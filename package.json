{
  "name": "clip-harbor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build && wrangler deploy --dry-run --outdir .wrangler/tmp/build",
    "check": "vp check",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "wrangler dev",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "local:publish": "bash scripts/publish-local-origin.sh",
    "local:start": "bash scripts/start-local-origin.sh",
    "local:status": "bash scripts/status-local-origin.sh",
    "local:stop": "bash scripts/stop-local-origin.sh",
    "origin:publish": "pnpm run local:publish",
    "origin:start": "pnpm run local:start",
    "origin:status": "pnpm run local:status",
    "origin:stop": "pnpm run local:stop",
    "smoke": "node --experimental-strip-types scripts/smoke-harness.ts",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260414.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16",
    "wrangler": "^4.82.2"
  },
  "packageManager": "pnpm@10.15.1"
}
